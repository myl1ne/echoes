{
  "name": "shell-avatar",
  "version": "0.1.0",
  "description": "Digital avatar kiosk — perception/action loop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "pack": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@mediapipe/tasks-vision": "^0.10.32",
    "@vladmandic/face-api": "^1.7.15",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.0.0",
    "face-api.js": "^0.22.2",
    "hammerjs": "^2.0.8",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "6",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.echoes.shell-avatar",
    "productName": "Shell Avatar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**",
      "!.gitignore",
      "!*.md"
    ],
    "asarUnpack": [
      "node_modules/@xenova/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/@vladmandic/**",
      "models/**",
      "Characters/**",
      "Backgrounds/**",
      "lib/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Shell Avatar"
    }
  }
}
