  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google-cloud/firestore": "^8.3.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.3.7",
    "openai": "^6.10.0",
    "pdf-parse": "^1.1.4",
