# OpenAI API Key for Cassandra chat
# Get your API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: OpenAI model to use (default: gpt-4-turbo-preview)
# Options: gpt-4-turbo-preview, gpt-3.5-turbo, gpt-4, etc.
VITE_CASSANDRA_MODEL=gpt-4-turbo-preview

# Optional: Port for Cassandra API server (default: 3001)
CASSANDRA_PORT=3001
