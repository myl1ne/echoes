# Anthropic API Key — powers Cassandra chat, Thread heartbeat, and voice analyzer
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model for Cassandra and Thread (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
CASSANDRA_MODEL=claude-sonnet-4-6

# Optional: Override model specifically for Thread's heartbeat (default: same as CASSANDRA_MODEL)
# THREAD_MODEL=claude-opus-4-6

# Optional: ElevenLabs API key for text-to-speech audio generation
# Get your API key from https://elevenlabs.io
ELEVENLABS_API_KEY=sk-your-elevenlabs-api-key-here

# Optional: Admin token for admin endpoints (required for /admin/* and /api/thread/* routes)
CASSANDRA_ADMIN_TOKEN=your-secret-admin-token-here

# Optional: Port for Cassandra API server (default: 3001)
CASSANDRA_PORT=3001

# Tavily API key — web search for poll_noosphere tool (Cassandra + Thread)
# Get your API key from https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-your-key-here

# Optional: Storage backend (default: local filesystem for dev, firestore for production)
# STORAGE_BACKEND=firestore

# Legacy — no longer needed server-side (Cassandra now uses Claude/Anthropic, not OpenAI)
# Keep if you use OpenAI for other purposes. Remove if not needed.
# VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
