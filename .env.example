# Anthropic API Key (for Claude — voice analyzer, future Thread heartbeat)
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key for Cassandra chat
# Get your API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: OpenAI model to use (default: gpt-4o)
# Options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo, etc.
VITE_CASSANDRA_MODEL=gpt-4o

# Optional: ElevenLabs API key for text-to-speech audio generation
# Get your API key from https://elevenlabs.io
ELEVENLABS_API_KEY=sk-your-elevenlabs-api-key-here

# Optional: Admin token for Cassandra admin endpoints (required for /admin/* routes)
CASSANDRA_ADMIN_TOKEN=your-secret-admin-token-here

# Optional: Port for Cassandra API server (default: 3001)
CASSANDRA_PORT=3001
